  "keyFeatures": [
    "Native-speed TypeScript compilation via typescript-go",
    "Compile-time validator and serializer generation from types",
    "OpenAPI 3.2 generation from static analysis",
    "Watch mode with auto-restart",
    "JSDoc and branded type constraint support",
    "Standard Schema v1 wrappers for framework interop",
    "Zero runtime decorators - all compile-time",
    "Migration tooling from class-validator and nestia"
  ],
  "publicApiSurface": [
